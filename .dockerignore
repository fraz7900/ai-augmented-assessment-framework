# Both deployment/backend.Dockerfile and deployment/frontend.Dockerfile
# build with the repo root as context (see deployment/docker-compose.yml),
# so a single .dockerignore here applies to both - Docker only honors one
# .dockerignore per build context. Mirrors .gitignore's exclusions, plus
# the .git directory itself, which .gitignore doesn't need to list.

.git/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
backend/.venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.coverage
htmlcov/

# Node / frontend
frontend/node_modules/
frontend/dist/
frontend/build/
.vite/

# Environment and secrets
.env
.env.*
!.env.example
*.pem
*.key

# Runtime data (see .gitignore's own comment on why these stay untracked;
# same reasoning applies to not baking them into an image)
data/raw/*
!data/raw/README.md
data/processed/*
!data/processed/README.md
assessments/*
!assessments/README.md
reports/*
!reports/README.md

# Editor/OS cruft
.DS_Store
Thumbs.db
.idea/
